    "m_SourceType": 1,
    "m_FunctionName": "Fuck",
    "m_FunctionSource": "",
    "m_FunctionBody": "float2 t = smoothstep(abs(round(Coord) - Coord + float2(0.5, 0.5)), Threshold / 2, Smoothness);\nIntensity = max(t.x, t.y);"
}

