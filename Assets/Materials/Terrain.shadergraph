        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "AAA",
    "m_FunctionSource": "",
    "m_FunctionBody": "float u = x / step;\r\nfloat delta = u - round(u);\r\nOut = 1.0 - smoothstep(0.0, h1, delta) - smoothstep(h2, h2, -delta);"
}

